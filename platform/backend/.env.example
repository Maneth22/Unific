# --- Database ---
DATABASE_URL=postgresql+asyncpg://unific:unific_dev_password@localhost:55432/unific_platform

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-generate-a-real-64-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Secrets encryption (Account Registry credential envelope) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# --- CORS ---
CORS_ORIGINS=http://localhost:5183

# --- Login protection ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Providers ---
# WhatsApp stays mock until Cloud API credentials exist.
WHATSAPP_PROVIDER=mock
# Reply drafting + translation use Gemini once GEMINI_API_KEY is set below;
# fall back to TRANSLATION_PROVIDER=mock / REPLY_PROVIDER=stub with no key.
TRANSLATION_PROVIDER=gemini
REPLY_PROVIDER=gemini
# The Meeting Room's intermediary agent (clarify inbound, tone analysis,
# outbound translation in character voice, session/satisfaction reports).
# "gemini" or "mock".
COMMS_AGENT_PROVIDER=gemini

# WhatsApp Cloud API (only used when WHATSAPP_PROVIDER=cloud_api)
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERIFY_TOKEN=

# --- Gemini (used when TRANSLATION_PROVIDER=gemini / REPLY_PROVIDER=gemini) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_RATE_LIMIT_DELAY=0.2
GEMINI_MAX_CONCURRENT=4

# --- Environment ---
ENVIRONMENT=development
